digraph urd {
  rankdir=LR;
  node [shape=box, fontname="Helvetica"];
  "ops-assistant" [shape=hexagon, style=filled, fillcolor="#dbeafe"];
  "admin" [style=filled, fillcolor="#fee2e2", label="admin\n[high]"];
  "weather" [style=filled, fillcolor="#dcfce7", label="weather\n[low]"];
  "ops-assistant" -> "weather" [color=black, label="declared"];
  "ops-assistant" -> "admin" [color=black, label="declared"];
}